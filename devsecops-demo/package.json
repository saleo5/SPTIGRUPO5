{
  "name": "devsecops-demo",
  "version": "1.0.0",
  "description": "Demo de automatización y remediación de fallos de seguridad en DevSecOps",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "audit": "npm audit --production",
    "audit:json": "npm audit --production --json",
    "outdated": "npm outdated",
    "security-check": "npm audit && npm outdated",
    "sast": "bash scripts/run-sast.sh",
    "sca": "bash scripts/run-sca.sh"
  },
  "dependencies": {
    "express": "4.21.2",
    "sqlite3": "5.1.7",
    "dotenv": "16.4.7",
    "bcrypt": "5.1.1"
  },
  "devDependencies": {
    "nodemon": "3.1.7"
  },
  "keywords": ["devsecops", "security", "demo", "sast", "sca"],
  "author": "SPTIGRUPO5",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}

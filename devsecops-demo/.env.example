# .env.example - Template de variables de entorno
# Nunca commitear este archivo con valores reales
# Usar: cp .env.example .env  y llenar con valores reales

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_me_in_production
DB_NAME=myapp

# API Keys (NUNCA hardcodear en el código)
API_KEY=your_api_key_here
STRIPE_KEY=sk_live_your_stripe_key
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret

# Slack Webhook
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# JWT
JWT_SECRET=your_jwt_secret_key_min_32_chars

# Environment
NODE_ENV=development
PORT=3000

# GitHub Token (para GitHub Actions)
GITHUB_TOKEN=ghp_your_personal_token_here
